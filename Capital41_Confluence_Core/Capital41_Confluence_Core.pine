// CAPITAL41 CONFLUENCE CORE

// What it does:
// - Combines trend (MA), RSI, Williams %R, and Liquidity Sweep into one clear
//   long/short signal.
// - Includes a compact single-row status badge on the last bar.
// - Non-repainting: signals only after bar close.
//
// TradingView setup:
// 1) Open TradingView -> Pine Editor.
// 2) Paste this script, Save, and Add to chart.
// 3) Use 30m or 4h on BTC or US stocks.
// 4) Adjust Signal strictness to control frequency.

// Usage guide (30m/4h):
// - Standard mode is balanced. Use Strict for fewer signals, Loose for more.
// - Trend filter uses MA; signals only fire with the MA direction.
// - Liquidity sweeps confirm reversal into the trend direction.



//@version=6
indicator("Capital41 Confluence Core", overlay = true, max_labels_count = 50)

// Inputs tuned for 30m-4H
maType        = input.string("EMA", "MA type", options = ["EMA", "SMA"])
maLen         = input.int(50, "MA length", minval = 5)

rsiLen        = input.int(14, "RSI length", minval = 2)
rsiOB         = input.int(65, "RSI overbought", minval = 50, maxval = 80)
rsiOS         = input.int(35, "RSI oversold", minval = 20, maxval = 50)

wrLen         = input.int(14, "Williams %R length", minval = 2)
wrOB          = input.float(-20.0, "Williams %R overbought")
wrOS          = input.float(-80.0, "Williams %R oversold")

sweepLookback = input.int(20, "Sweep lookback", minval = 5)
volLookback   = input.int(50, "Volume SMA length", minval = 5)
minVolRatio   = input.float(1.2, "Min volume ratio", minval = 1.0, maxval = 3.0)

signalMode    = input.string("Standard", "Signal strictness", options = ["Strict", "Standard", "Loose"])
zoneBuffer    = input.int(5, "Zone buffer", minval = 0, maxval = 20)

showMA        = input.bool(true, "Show moving average")
showSignals   = input.bool(true, "Show confluence signals")
showBadge     = input.bool(true, "Show status badge")

colorBull    = color.new(color.lime, 0)
colorBear    = color.new(color.red, 0)
colorNeutral = color.new(color.gray, 80)


// Moving average
ma = maType == "EMA" ? ta.ema(close, maLen) : ta.sma(close, maLen)
plot(showMA ? ma : na, title = "MA", color = color.new(color.gray, 0), linewidth = 2)

// RSI
rsi = ta.rsi(close, rsiLen)
rsiOSLoose = rsiOS + zoneBuffer
rsiOBLoose = rsiOB - zoneBuffer

rsiLongStrict   = rsi < rsiOS and rsi > rsi[1]
rsiLongStandard = rsi < rsiOS or (rsi < rsiOSLoose and rsi > rsi[1])
rsiLongLoose    = rsi < rsiOSLoose

rsiShortStrict   = rsi > rsiOB and rsi < rsi[1]
rsiShortStandard = rsi > rsiOB or (rsi > rsiOBLoose and rsi < rsi[1])
rsiShortLoose    = rsi > rsiOBLoose

rsiLong  = signalMode == "Strict" ? rsiLongStrict : signalMode == "Loose" ? rsiLongLoose : rsiLongStandard
rsiShort = signalMode == "Strict" ? rsiShortStrict : signalMode == "Loose" ? rsiShortLoose : rsiShortStandard

// Williams %R
wr_manual(_high, _low, _close, _len) =>
    hh = ta.highest(_high, _len)
    ll = ta.lowest(_low, _len)
    rng = hh - ll
    rng == 0 ? -50.0 : (hh - _close) / rng * -100

wr = wr_manual(high, low, close, wrLen)
wrOSLoose = wrOS + zoneBuffer
wrOBLoose = wrOB - zoneBuffer
wrLongStrict   = wr < wrOS and wr > wr[1]
wrLongStandard = wr < wrOS or (wr < wrOSLoose and wr > wr[1])
wrLongLoose    = wr < wrOSLoose
wrShortStrict   = wr > wrOB and wr < wr[1]
wrShortStandard = wr > wrOB or (wr > wrOBLoose and wr < wr[1])
wrShortLoose    = wr > wrOBLoose

wrLong  = signalMode == "Strict" ? wrLongStrict : signalMode == "Loose" ? wrLongLoose : wrLongStandard
wrShort = signalMode == "Strict" ? wrShortStrict : signalMode == "Loose" ? wrShortLoose : wrShortStandard

// Liquidity sweep
priorHigh = ta.highest(high[1], sweepLookback)
priorLow  = ta.lowest(low[1],  sweepLookback)

volSma   = ta.sma(volume, volLookback)
volRatio = volSma > 0 ? volume / volSma : 0
volThresh = signalMode == "Strict" ? minVolRatio * 1.2 : signalMode == "Loose" ? minVolRatio * 0.9 : minVolRatio
highVol  = volRatio >= volThresh

bullSweep = low < priorLow and close >= priorLow and highVol and barstate.isconfirmed
bearSweep = high > priorHigh and close <= priorHigh and highVol and barstate.isconfirmed

// Confluence
trendLong  = close > ma
trendShort = close < ma

longSignal  = showSignals and trendLong and bullSweep and rsiLong and wrLong
shortSignal = showSignals and trendShort and bearSweep and rsiShort and wrShort

plotshape(longSignal, title = "Confluence Long",
          style = shape.triangleup, location = location.belowbar,
          color = colorBull, size = size.small, text = "L")

plotshape(shortSignal, title = "Confluence Short",
          style = shape.triangledown, location = location.abovebar,
          color = colorBear, size = size.small, text = "S")

alertcondition(longSignal, title = "Confluence Long",
               message = "Confluence Long: MA + RSI + WR + Sweep aligned on {{ticker}} ({{interval}})")

alertcondition(shortSignal, title = "Confluence Short",
               message = "Confluence Short: MA + RSI + WR + Sweep aligned on {{ticker}} ({{interval}})")

// Status badge (single row)
var table status = table.new(position.top_right, 5, 1, border_width = 1)


if barstate.islast
    if showBadge
        maText = trendLong ? "MA+" : trendShort ? "MA-" : "MA0"
        swText = bullSweep ? "SW+" : bearSweep ? "SW-" : "SW0"
        rsiText = rsiLong ? "RSI+" : rsiShort ? "RSI-" : "RSI0"
        wrText = wrLong ? "WR+" : wrShort ? "WR-" : "WR0"
        sigText = longSignal ? "SIG L" : shortSignal ? "SIG S" : "SIG -"

        table.cell(status, 0, 0, maText, bgcolor = trendLong ? color.new(colorBull, 70) : trendShort ? color.new(colorBear, 70) : colorNeutral, text_color = color.white, text_size = size.tiny)
        table.cell(status, 1, 0, swText, bgcolor = bullSweep ? color.new(colorBull, 70) : bearSweep ? color.new(colorBear, 70) : colorNeutral, text_color = color.white, text_size = size.tiny)
        table.cell(status, 2, 0, rsiText, bgcolor = rsiLong ? color.new(colorBull, 70) : rsiShort ? color.new(colorBear, 70) : colorNeutral, text_color = color.white, text_size = size.tiny)
        table.cell(status, 3, 0, wrText, bgcolor = wrLong ? color.new(colorBull, 70) : wrShort ? color.new(colorBear, 70) : colorNeutral, text_color = color.white, text_size = size.tiny)
        table.cell(status, 4, 0, sigText, bgcolor = longSignal ? color.new(colorBull, 60) : shortSignal ? color.new(colorBear, 60) : colorNeutral, text_color = color.white, text_size = size.tiny)
    else
        for i = 0 to 4
            table.cell(status, i, 0, "", bgcolor = color.new(color.black, 100), text_color = color.new(color.black, 100))
